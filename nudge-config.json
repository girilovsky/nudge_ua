{
  "optionalFeatures": {
    "utilizeSOFAFeed": true,
    "aggressiveUserExperience": false,
    "aggressiveUserFullScreenExperience": false,
    "acceptableCameraUsage": true,
    "acceptableScreenSharingUsage": true,
    "acceptableApplicationBundleIDs": [
      "us.zoom.xos",
      "com.microsoft.teams2",
      "com.webex.meetingmanager"
    ],
    "randomDelay": true,
    "attemptToCheckForSupportedDevice": true
  },
  "userExperience": {
    "allowedDeferrals": 30,
    "allowedDeferralsUntilForcedSecondaryQuitButton": 20,
    "allowCustomDeferralDate": true,
    "initialRefreshCycle": 18000,
    "approachingWindowTime": 72,
    "imminentWindowTime": 24
  },
  "userInterface": {
    "simpleMode": true,
    "showDaysRemainingToUpdate": true,
    "maxDaysToRespond": 7,
    "fallbackLanguage": "en",
    "iconDarkPath": "/Applications/Company Portal.app/Contents/Resources/AppIcon.icns",
    "iconLightPath": "/Applications/Company Portal.app/Contents/Resources/AppIcon.icns",
    "updateElements": [
      {
        "_language": "en",
        "mainHeader": "Your Mac requires a security update",
        "subHeader": "A friendly reminder from IT team",
        "actionButtonText": "Update Device",
        "primaryQuitButtonText": "Later",
        "secondaryQuitButtonText": "I understand",
        "informationButtonText": "More Info"
      },
      {
        "_language": "uk",
        "mainHeader": "Ваш Mac потребує оновлення безпеки",
        "subHeader": "Нагадування від IT-команди",
        "actionButtonText": "Оновити пристрій",
        "primaryQuitButtonText": "Пізніше",
        "secondaryQuitButtonText": "Я розумію",
        "informationButtonText": "Детальніше"
      }
    ]
  },
  "osVersionRequirements": [
    {
      "requiredMinimumOSVersion": "latest-supported",
      "aboutUpdateURLs": [
        {
          "_language": "en",
          "aboutUpdateURL": "https://support.apple.com/en-us/100100"
        },
        {
          "_language": "uk",
          "aboutUpdateURL": "https://support.apple.com/uk-ua/100100"
        }
      ]
    }
  ]
}
